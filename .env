# .env.example


# =========================================================
# Parking System Environment
# Copy file này thành .env trước khi chạy:
# cp .env.example .env
# =========================================================

# =========================================================
# App
# =========================================================
APP_ENV=development
APP_DEBUG=true
TZ=Asia/Ho_Chi_Minh

# =========================================================
# Public URLs
# =========================================================
WEB_PUBLIC_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:8000
GATEWAY_PUBLIC_URL=ws://localhost:8300

# Frontend build/runtime config
VITE_API_URL=http://localhost:8000
VITE_GATEWAY_WS_URL=ws://localhost:8300/ws/web

# =========================================================
# External ports
# =========================================================
WEB_PORT_EXTERNAL=3000
API_PORT_EXTERNAL=8000
GATEWAY_PORT_EXTERNAL=8300

POSTGRES_PORT_EXTERNAL=5432
REDIS_PORT_EXTERNAL=6379
MINIO_PORT_EXTERNAL=9000
MINIO_CONSOLE_PORT_EXTERNAL=9001

NGINX_HTTP_PORT_EXTERNAL=80
NGINX_HTTPS_PORT_EXTERNAL=443

# =========================================================
# PostgreSQL
# =========================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=parking
POSTGRES_USER=parking
POSTGRES_PASSWORD=parking

DATABASE_URL=postgresql+psycopg://parking:parking@postgres:5432/parking

# =========================================================
# Redis
# =========================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=parking_redis_password

REDIS_URL=redis://:parking_redis_password@redis:6379/0

# Redis Streams - business events, commands, tasks
REDIS_STREAM_EVENTS=parking.events
REDIS_STREAM_COMMANDS=parking.commands
REDIS_STREAM_TASKS=parking.tasks
REDIS_STREAM_DEAD_LETTERS=parking.dead_letters

# Redis Pub/Sub - realtime UI, notifications
REDIS_CHANNEL_REALTIME=parking.realtime
REDIS_CHANNEL_NOTIFICATIONS=parking.notifications

# Consumer groups
REDIS_CONSUMER_GROUP_API=parking-api
REDIS_CONSUMER_GROUP_GATEWAY=parking-gateway
REDIS_CONSUMER_GROUP_WORKER=parking-worker

# =========================================================
# MinIO
# =========================================================
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=parking-media
MINIO_SECURE=false

# =========================================================
# Auth
# =========================================================
JWT_SECRET=CHANGE_ME_USE_OPENSSL_RAND_HEX_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_SECONDS=3600
JWT_REFRESH_TOKEN_EXPIRE_SECONDS=604800

# =========================================================
# Agent Auth
# =========================================================
AGENT_TOKEN_SECRET=CHANGE_ME_USE_OPENSSL_RAND_HEX_32
AGENT_TOKEN_EXPIRE_DAYS=365

# Device Agent
DEVICE_AGENT_ID=device-agent-gate-01
DEVICE_AGENT_TOKEN=CHANGE_ME_DEVICE_AGENT_TOKEN
DEVICE_AGENT_GATEWAY_WS_URL=ws://parking-gateway:8300/ws/device-agent

# Camera Agent
CAMERA_AGENT_ID=camera-agent-gate-01
CAMERA_AGENT_TOKEN=CHANGE_ME_CAMERA_AGENT_TOKEN
CAMERA_AGENT_GATEWAY_WS_URL=ws://parking-gateway:8300/ws/camera-agent

# =========================================================
# API
# =========================================================
API_HOST=0.0.0.0
API_PORT=8000

# =========================================================
# Gateway
# =========================================================
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8300
GATEWAY_HEARTBEAT_INTERVAL=30
GATEWAY_HEARTBEAT_TIMEOUT=90

# =========================================================
# Workers
# =========================================================
WORKER_CONCURRENCY=2

# OCR
MOCK_OCR=true
OCR_ENGINE=paddleocr
OCR_DEVICE=cpu

# ALPR
MOCK_ALPR=true
ALPR_ENGINE=yolo_paddleocr
ALPR_DEVICE=cpu

# Face
MOCK_FACE=true
FACE_ENGINE=insightface
FACE_DEVICE=cpu

# GPU option
CUDA_VISIBLE_DEVICES=0

# =========================================================
# Camera
# =========================================================
MOCK_CAMERA=true
CAMERA_SNAPSHOT_QUALITY=90
CAMERA_RECONNECT_INTERVAL=5
CAMERA_DEFAULT_FPS=10
CAMERA_FRAME_BUFFER_SIZE=100

# =========================================================
# RFID / Barrier
# =========================================================
MOCK_RFID=true
MOCK_BARRIER=true

# =========================================================
# Media retention
# =========================================================
IMAGE_RETENTION_DAYS=180
VIDEO_RETENTION_DAYS=30
AUDIT_LOG_RETENTION_DAYS=365
DEVICE_EVENT_RETENTION_DAYS=90

# =========================================================
# Logging
# =========================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# =========================================================
# Development flags
# =========================================================
ENABLE_SWAGGER=true
ENABLE_DEBUG_ROUTES=true
ENABLE_MOCK_DATA=true

